{
  "name": "ormb",
  "version": "0.0.0",
  "private": true,
  "description": "Testnet-first, whitelisted stablecoin issuance and enterprise settlement demo.",
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "test": "tsx --test \"test/**/*.unit.test.ts\"",
    "test:e2e": "playwright test",
    "compile:contracts": "hardhat compile",
    "test:contracts": "hardhat test test/contracts/tooling.test.ts test/contracts/ormb-token.test.ts",
    "deploy:contracts": "hardhat run scripts/deploy-contracts.ts --network baseSepolia",
    "contracts:whitelist": "hardhat run scripts/whitelist-wallet.ts --network baseSepolia",
    "contracts:manual-mint": "hardhat run scripts/manual-mint.ts --network baseSepolia",
    "contracts:minter-role": "hardhat run scripts/manage-minter-role.ts --network baseSepolia",
    "typecheck": "tsc --noEmit",
    "lint": "node -e \"console.log('placeholder: lint not implemented yet')\"",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate:local": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "npm run demo:seed",
    "db:reset:local": "prisma migrate reset && npm run db:seed",
    "demo:seed": "tsx scripts/seed-demo.ts",
    "backfill:dry-run": "tsx scripts/backfill-deposits-dry-run.ts",
    "staging:preflight": "tsx scripts/preflight-private-staging.ts",
    "staging:tx-dry-run": "tsx scripts/dry-run-live-mint-burn.ts",
    "deploy:preflight": "tsx scripts/preflight-base-sepolia-deploy.ts",
    "test:ci": "npm run lint && npm run prisma:generate && npm run typecheck && npm run prisma:validate && npm run test && npm run compile:contracts && npm run test:contracts && npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.7",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "hardhat": "^3.9.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2.52.2"
  }
}
